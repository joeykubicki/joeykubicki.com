rules_version = '2';

// Expedition — Firestore security rules
//
// One document per user at users/{uid}. A signed-in person can read and
// write ONLY their own document. Nobody can list other users' data, and
// signed-out visitors can't touch the database at all.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid;
    }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
